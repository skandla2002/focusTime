{
  "name": "focus-timer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "preprompt": "node .workflowSvc/ai/generate-preprompt.js",
    "preprompt:approved": "node .workflowSvc/ai/generate-preprompt.js --approved",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "cap:build": "npm run build && npx cap sync android",
    "android:keystore": "powershell -ExecutionPolicy Bypass -File ./scripts/android/create-release-keystore.ps1",
    "android:keyprops": "powershell -ExecutionPolicy Bypass -File ./scripts/android/write-key-properties.ps1",
    "apk:debug": "npm run build && npx cap sync android && cd android && gradlew.bat assembleDebug",
    "apk:release": "npm run build && npx cap sync android && cd android && gradlew.bat assembleRelease",
    "aab:release": "npm run build && npx cap sync android && cd android && gradlew.bat bundleRelease",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@sentry/react": "^9.13.0",
    "@supabase/supabase-js": "^2.99.1",
    "chart.js": "^4.4.0",
    "firebase": "^11.6.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@storybook/addon-essentials": "8",
    "@storybook/react": "8",
    "@storybook/react-vite": "8",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "storybook": "8",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.26.0",
    "vite": "^5.0.8",
    "vitest": "^3.1.1"
  },
  "packageManager": "pnpm@9.0.0+sha256.bdfc9a7b372b5c462176993e586492603e20da5864d2f8881edc2462482c76fa"
}
